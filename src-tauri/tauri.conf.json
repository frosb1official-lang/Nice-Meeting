{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "nice-meeting",
  "version": "0.1.1",
  "identifier": "com.frosbi.dev",
  "build": {
    "frontendDist": "../src",
    "devUrl": null,
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Nice Meeting",
        "width": 1400,
        "height": 900,
        "minWidth": 640,
        "minHeight": 580,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/cover.png",
      "icons/icon.ico"
    ]
  }
}
